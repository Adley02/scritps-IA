    print("="*50)
    print("PROJETO 2 - INTELIGÊNCIA ARTIFICIAL COMPUTACIONAL")
    print("="*50)
    print("[1] Gerar Tabela 1: Classificadores (Dataset LoL)")
    print("[2] Gerar Tabela 2: Regressores (Dataset Academia)")
    print("[0] Sair")
    print("="*50)
    
    escolha = input("\nDigite o número da opção desejada: ")
    
    if escolha == '1':
        print("\n>>> INICIANDO TAREFA DE CLASSIFICAÇÃO (LoL) <<<")
        caminho_arquivo = 'league_dataset.arff' 
        X_completo, y_completo = carregar_dataset_lol(caminho_arquivo)
        
        # Redutor opcional para agilizar
        tamanho_desejado = 15000
        if len(y_completo) > tamanho_desejado:
            indices_aleatorios = np.random.choice(len(y_completo), tamanho_desejado, replace=False)
            X_completo = X_completo[indices_aleatorios]
            y_completo = y_completo[indices_aleatorios]
            print(f"Dataset reduzido para {tamanho_desejado} instâncias para agilizar K-Fold.")

        X_norm = normalizar_dados(X_completo)
        
        modelos_para_testar = [
            (KNNClassificador(k=5, metrica='euclidiana'), "K-vizinhos (Dist. Euclidiana)"),
            (KNNClassificador(k=5, metrica='manhattan'), "K-vizinhos (Dist. Manhattan)"),
            (BayesianoUnivariado(), "Bayesiano (Univariado)"),
            (BayesianoMultivariado(), "Bayesiano (Multivariado)")
        ]
        
        resultados_tabela = []
        for modelo, nome in modelos_para_testar:
            resultado = validacao_cruzada(modelo, nome, X_norm, y_completo, k_folds=5)
            resultados_tabela.append(resultado)
            
        print("\n" + "="*95)
        print(f"TABELA 1: ANÁLISE COMPARATIVA DE CLASSIFICADORES")
        print("-" * 95)
        print(f"{'Classificador':<30} | {'Acurácia':<15} | {'Precisão':<15} | {'F1-Score':<15} | {'T. Treino (s)':<15} | {'T. Teste (s)'}")
        print("-" * 95)
        for res in resultados_tabela:
            print(f"{res['Modelo']:<30} | {res['Acurácia']:<15} | {res['Precisão']:<15} | {res['F1-Score']:<15} | {res['Tempo Treino (s)']:<15} | {res['Tempo Teste (s)']}")
        print("=" * 95)

    elif escolha == '2':
        print("\n>>> INICIANDO TAREFA DE REGRESSÃO (Academia) <<<")
        caminho_arquivo_academia = 'campus_gym.arff' 
        X_completo, y_completo = carregar_dataset_academia(caminho_arquivo_academia)
        
        # Redutor opcional para agilizar
        tamanho_desejado = 15000
        if len(y_completo) > tamanho_desejado:
            indices_aleatorios = np.random.choice(len(y_completo), tamanho_desejado, replace=False)
            X_completo = X_completo[indices_aleatorios]
            y_completo = y_completo[indices_aleatorios]
            print(f"Dataset de Regressão reduzido para {tamanho_desejado} instâncias para agilizar o K-Fold.")

        X_norm = normalizar_dados(X_completo)
        
        regressores_para_testar = [
            (KNNRegressor(k=5, metrica='euclidiana'), "K-vizinhos Regressor (Euclidiana)"),
            (KNNRegressor(k=5, metrica='manhattan'), "K-vizinhos Regressor (Manhattan)"),
            (RegressaoLinearMultipla(), "Regressão Linear Múltipla")
        ]
        
        resultados_tabela_regressao = []
        for modelo, nome in regressores_para_testar:
            resultado = validacao_cruzada_regressao(modelo, nome, X_norm, y_completo, k_folds=5)
            resultados_tabela_regressao.append(resultado)
            
        print("\n" + "="*105)
        print(f"TABELA 2: ANÁLISE COMPARATIVA DE REGRESSORES")
        print("-" * 105)
        print(f"{'Regressão':<35} | {'R2-Score':<15} | {'R2-Ajustado':<15} | {'T. Treino (s)':<15} | {'T. Teste (s)'}")
        print("-" * 105)
        for res in resultados_tabela_regressao:
            print(f"{res['Modelo']:<35} | {res['R2-Score']:<15} | {res['R2-Ajustado']:<15} | {res['Tempo Treino (s)']:<15} | {res['Tempo Teste (s)']}")
        print("=" * 105)

    elif escolha == '0':
        print("\nSaindo do programa. Bom trabalho!")
        
    else:
        print("\nOpção inválida! Rode o script novamente e escolha 1, 2 ou 0.")
